{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit(config/.env*)|Write(config/.env*)",
        "hooks": [{
          "type": "command",
          "command": "echo 'BLOCKED: Edit .env files manually, not via Claude' >&2; exit 2"
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit(skills/**/*.yaml)|Write(skills/**/*.yaml)",
        "hooks": [{
          "type": "command",
          "command": "echo 'Reminder: Run python3 scripts/validate.py to verify skill YAML changes'"
        }]
      }
    ]
  }
}
